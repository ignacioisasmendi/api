generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  auth0UserId    String          @unique
  email          String          @unique
  name           String?
  avatar         String?
  plan           UserPlan        @default(BETA)
  status         UserStatus      @default(ACTIVE)
  createdAt      DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(3)
  calendars      Calendar[]
  clients        Client[]
  comments       Comment[]
  contents       Content[]
  oauthStates    OAuthState[]
  socialAccounts  SocialAccount[]
  feedbackReports FeedbackReport[]
}

model Client {
  id             String          @id @default(cuid())
  userId         String
  name           String          @db.VarChar(100)
  avatar         String?
  createdAt      DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(3)
  logoUrl   String?
  logoKey   String?
  calendars      Calendar[]
  campaigns      Campaign[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  contents       Content[]
  socialAccounts SocialAccount[]
  taskBoards     TaskBoard[]

  @@unique([userId, name])
  @@index([userId])
}

model SocialAccount {
  id               String        @id @default(cuid())
  userId           String
  clientId         String
  platform         Platform
  accessToken      String?
  refreshToken     String?
  expiresAt        DateTime?     @db.Timestamptz(3)
  platformUserId   String?
  username         String?
  metadata         Json?
  isActive         Boolean       @default(true)
  disconnectedAt   DateTime?     @db.Timestamptz(3)
  createdAt        DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime      @updatedAt @db.Timestamptz(3)
  refreshExpiresAt DateTime?     @db.Timestamptz(6)
  publications     Publication[]
  client           Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, platform, platformUserId])
  @@index([userId])
  @@index([clientId])
  @@index([platform])
  @@index([disconnectedAt])
}

model Content {
  id           String        @id @default(cuid())
  userId       String
  clientId     String
  calendarId   String?
  caption      String?
  createdAt    DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(3)
  calendar     Calendar?     @relation(fields: [calendarId], references: [id])
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  media        Media[]
  publications Publication[]

  @@index([userId])
  @@index([clientId])
  @@index([calendarId])
}

model Campaign {
  id           String        @id @default(cuid())
  name         String
  description  String?
  startDate    DateTime?     @db.Timestamptz(3)
  endDate      DateTime?     @db.Timestamptz(3)
  color        String?
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  publications Publication[]
  createdAt    DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(3)

  @@index([clientId])
}

model Publication {
  id              String             @id @default(cuid())
  contentId       String
  socialAccountId String
  campaignId      String?
  platform        Platform
  format          ContentFormat
  publishAt       DateTime           @db.Timestamptz(3)
  status          PublicationStatus  @default(SCHEDULED)
  error           String?
  customCaption   String?
  platformConfig  Json?
  platformId      String?
  link            String?
  createdAt       DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime           @updatedAt @db.Timestamptz(3)
  kanbanColumnId  String?
  kanbanOrder     Int                @default(0)
  containerId     String?
  campaign        Campaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  comments        Comment[]
  content         Content            @relation(fields: [contentId], references: [id], onDelete: Cascade)
  kanbanColumn    KanbanColumn?      @relation(fields: [kanbanColumnId], references: [id])
  socialAccount   SocialAccount      @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  mediaUsage      PublicationMedia[]

  @@index([publishAt])
  @@index([status])
  @@index([socialAccountId])
  @@index([contentId])
  @@index([kanbanColumnId])
  @@index([campaignId])
}

model Media {
  id               String             @id @default(cuid())
  contentId        String
  url              String
  key              String
  type             MediaType
  mimeType         String
  size             Int
  width            Int?
  height           Int?
  duration         Int?
  thumbnail        String?
  order            Int                @default(0)
  createdAt        DateTime           @default(now()) @db.Timestamptz(3)
  content          Content            @relation(fields: [contentId], references: [id], onDelete: Cascade)
  publicationUsage PublicationMedia[]

  @@index([contentId])
  @@index([type])
}

model PublicationMedia {
  id            String      @id @default(cuid())
  publicationId String
  mediaId       String
  order         Int         @default(0)
  cropData      Json?
  media         Media       @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  publication   Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@unique([publicationId, mediaId])
  @@index([publicationId])
  @@index([mediaId])
}

model OAuthState {
  id           String   @id @default(uuid())
  state        String   @unique
  provider     String
  userId       String
  used         Boolean  @default(false)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  expiresAt    DateTime @db.Timestamptz(3)
  codeVerifier String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([state])
  @@index([userId])
}

model Calendar {
  id            String              @id @default(cuid())
  userId        String
  clientId      String
  name          String
  description   String?
  createdAt     DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime            @updatedAt @db.Timestamptz(3)
  client        Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  shareLinks    CalendarShareLink[]
  comments      Comment[]
  contents      Content[]
  kanbanColumns KanbanColumn[]

  @@index([userId])
  @@index([clientId])
}

model KanbanColumn {
  id           String        @id @default(cuid())
  calendarId   String
  name         String
  order        Int           @default(0)
  mappedStatus String?
  color        String?
  createdAt    DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(6)
  calendar     Calendar      @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  publications Publication[]

  @@index([calendarId])
  @@index([calendarId, order])
}

model CalendarShareLink {
  id             String          @id @default(cuid())
  calendarId     String
  tokenHash      String          @unique
  label          String?
  permission     SharePermission @default(VIEW_AND_COMMENT)
  isActive       Boolean         @default(true)
  expiresAt      DateTime?       @db.Timestamptz(3)
  createdAt      DateTime        @default(now()) @db.Timestamptz(3)
  revokedAt      DateTime?       @db.Timestamptz(3)
  lastAccessedAt DateTime?       @db.Timestamptz(3)
  accessCount    Int             @default(0)
  calendar       Calendar        @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  comments       Comment[]

  @@index([calendarId])
  @@index([tokenHash])
}

model Comment {
  id            String             @id @default(cuid())
  calendarId    String
  publicationId String?
  authorName    String
  authorEmail   String?
  body          String
  shareLinkId   String?
  userId        String?
  commenterId   String?
  isResolved    Boolean            @default(false)
  createdAt     DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime           @updatedAt @db.Timestamptz(3)
  calendar      Calendar           @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  publication   Publication?       @relation(fields: [publicationId], references: [id])
  shareLink     CalendarShareLink? @relation(fields: [shareLinkId], references: [id])
  user          User?              @relation(fields: [userId], references: [id])

  @@index([calendarId])
  @@index([publicationId])
  @@index([shareLinkId])
  @@index([commenterId])
}

model WaitlistEntry {
  id        String    @id @default(cuid())
  email     String    @unique
  invitedAt DateTime? @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)

  @@map("waitlist_entries")
}

enum UserPlan {
  BETA
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum UserStatus {
  WAITLISTED
  ACTIVE
  SUSPENDED
}

enum ContentFormat {
  FEED
  STORY
  REEL
  VIDEO
  CAROUSEL
  ARTICLE
  TWEET
}

enum PublicationStatus {
  SCHEDULED
  PREPARING
  READY
  PUBLISHING
  PUBLISHED
  ERROR
}

enum Platform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  LINKEDIN
  X
  CANVA
}

enum MediaType {
  IMAGE
  VIDEO
  THUMBNAIL
}

enum SharePermission {
  VIEW_ONLY
  VIEW_AND_COMMENT
}

enum FeedbackType {
  BUG
  SUGGESTION
  OTHER
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model FeedbackReport {
  id            String         @id @default(cuid())
  userId        String
  clientId      String?
  type          FeedbackType
  message       String
  screenshotUrl String?
  status        FeedbackStatus @default(OPEN)
  adminResponse String?
  respondedAt   DateTime?      @db.Timestamptz(3)
  createdAt     DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime       @updatedAt @db.Timestamptz(3)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model TaskBoard {
  id        String     @id @default(cuid())
  clientId  String
  name      String     @db.VarChar(100)
  color     String?
  createdAt DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt DateTime   @updatedAt @db.Timestamptz(3)
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lists     TaskList[]

  @@index([clientId])
}

model TaskList {
  id          String    @id @default(cuid())
  taskBoardId String
  name        String    @db.VarChar(100)
  order       Int       @default(0)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  taskBoard   TaskBoard @relation(fields: [taskBoardId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([taskBoardId])
  @@index([taskBoardId, order])
}

model Task {
  id          String        @id @default(cuid())
  taskListId  String
  title       String        @db.VarChar(500)
  description String?
  order       Int           @default(0)
  priority    TaskPriority?
  dueDate     DateTime?     @db.Timestamptz(3)
  labels      String[]
  coverColor  String?
  done        Boolean       @default(false)
  createdAt   DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(3)
  taskList    TaskList      @relation(fields: [taskListId], references: [id], onDelete: Cascade)
  checklist   ChecklistItem[]
  blockedBy   TaskDependency[] @relation("BlockedTask")
  blocking    TaskDependency[] @relation("BlockingTask")

  @@index([taskListId])
  @@index([taskListId, order])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  title     String   @db.VarChar(500)
  done      Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskDependency {
  id          String   @id @default(cuid())
  taskId      String
  blockedById String
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  task        Task     @relation("BlockedTask", fields: [taskId], references: [id], onDelete: Cascade)
  blockedBy   Task     @relation("BlockingTask", fields: [blockedById], references: [id], onDelete: Cascade)

  @@unique([taskId, blockedById])
  @@index([taskId])
  @@index([blockedById])
}
